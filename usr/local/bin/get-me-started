#!/bin/bash

# Exit on error, undefined variables, and pipe failures
set -Euo pipefail

# Source common library
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

TARGET_USER="${SUDO_USER:-$USER}"


tput setaf 3;
log_section "SCRIPT TO REMOVE ELEMENTS WITH NO QUESTIONS ASKED"
echo "- SETUP HQ MACHINE"
echo "  - REMOVE BROADCOM AND REALTEK DRIVERS"
echo "  - WRITE /etc/environment"
echo "  - INSTALL GTK 3.0 AND 4.0 CONFIG"
echo "  - SET ALACRITTY FONT SIZE TO 14"
tput sgr0

setup_hq() {
    if [[ "$(hostname)" != "hq" ]]; then
        return 0
    fi

    local package
    for package in broadcom-wl-dkms rtl8821cu-morrownr-dkms-git; do
        if pacman -Q "${package}" &>/dev/null; then
            log_subsection "Removing ${package}"
            sudo pacman -Rns --noconfirm "${package}" || log_warn "Failed to remove ${package}"
        else
            log_info "${package} is not installed"
        fi
    done

    log_subsection "Writing /etc/environment"
    sudo tee /etc/environment > /dev/null << 'EOF'
QT_QPA_PLATFORMTHEME=qt5ct
QT_STYLE_OVERRIDE=kvantum
GTK_THEME="Arc-Dawn-Dark"
EDITOR=nano
BROWSER=firefox
EOF
    log_success "/etc/environment written"

    log_subsection "HQ: installing GTK 3.0 and 4.0 config"

    mkdir -p "${HOME}/.config/gtk-3.0" "${HOME}/.config/gtk-4.0"

    tee "${HOME}/.config/gtk-3.0/settings.ini" > /dev/null << 'EOF'
[Settings]
gtk-theme-name=Arc-Dark
gtk-icon-theme-name=neo-candy-icons
gtk-font-name=Noto Sans 11
gtk-cursor-theme-name=Bibata-Modern-Ice
gtk-cursor-theme-size=0
gtk-toolbar-style=GTK_TOOLBAR_ICONS
gtk-toolbar-icon-size=GTK_ICON_SIZE_LARGE_TOOLBAR
gtk-button-images=1
gtk-menu-images=1
gtk-enable-event-sounds=0
gtk-enable-input-feedback-sounds=0
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle=hintslight
gtk-xft-rgba=rgb
EOF

    tee "${HOME}/.config/gtk-3.0/bookmarks" > /dev/null << 'EOF'
file:///home/erik/Documents
file:///home/erik/Downloads Downloads
file:///home/erik/Pictures Pictures
file:///home/erik/Projects
file:///home/erik/Videos Videos
file:///home/erik/Insync
file:///etc/skel /etc/skel
file:///home/erik/.config .config
file:///home/erik/.config/arco-chadwm
file:///home/erik/DATA DATA
file:///home/erik/EDU
file:///home/erik/EDU-PKG-BUILD
file:///home/erik/KIRO
file:///home/erik/kiro-Out
file:///home/erik/DATA/arcolinux-nemesis
file:///home/erik/.icons .icons
file:///usr/share/icons icons
file:///home/erik/.themes .themes
file:///usr/share/themes themes
file:///usr/share/applications applications
file:///home/erik/.config/ohmychadwm
file:///home/erik/EDU/nemesis_repo
file:///home/erik/KIRO/kiro_repo
file:///home/erik/Shared
EOF

    tee "${HOME}/.config/gtk-4.0/settings.ini" > /dev/null << 'EOF'
[Settings]
gtk-application-prefer-dark-theme=true
gtk-cursor-blink=true
gtk-cursor-blink-time=1000
gtk-cursor-theme-name=Bibata-Modern-Ice
gtk-cursor-theme-size=24
gtk-decoration-layout=icon:minimize,maximize,close
gtk-enable-animations=true
gtk-font-name=Noto Sans,  10
gtk-icon-theme-name=neo-candy-icons
gtk-primary-button-warps-slider=true
gtk-sound-theme-name=ocean
gtk-xft-dpi=98304
EOF

    chown -R "${TARGET_USER}:${TARGET_USER}" \
        "${HOME}/.config/gtk-3.0" \
        "${HOME}/.config/gtk-4.0"

    log_success "GTK 3.0 and 4.0 config installed for hq"

    log_subsection "Setting Alacritty font size to 14"
    sed -i 's/^size = .*/size = 14.0/' "${HOME}/.config/alacritty/alacritty.toml"
    log_success "Alacritty font size set to 14"
}


setup_hq

echo
echo "###############################################################################"
echo "###                DONE - YOU CAN CLOSE THIS WINDOW                        ####"
echo "###############################################################################"
