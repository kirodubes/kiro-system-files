#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false

main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Replace /etc/pacman.conf with the Kiro default" \
                    "[--help] [--version] [--dry-run]" \
                    ""
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            *)
                log_error "Unknown option: $arg"
                exit 1
                ;;
        esac
    done

    log_section "Getting /etc/pacman.conf"

    local local_pacman="/usr/local/share/kiro/pacman.conf"
    local github_url="https://raw.githubusercontent.com/erikdubois/arcolinux-nemesis/refs/heads/master/pacman.conf"

    if [[ -f "${local_pacman}" ]]; then
        log_subsection "Using local pacman.conf"
        if execute_or_dryrun "Copy local pacman.conf to /etc/pacman.conf" sudo cp "${local_pacman}" /etc/pacman.conf; then
            log_success "pacman.conf copied from local system"
            return 0
        else
            log_warn "Failed to copy local pacman.conf"
            exit 1
        fi
    fi

    log_info "Local pacman.conf not found at: ${local_pacman}"
    log_subsection "Checking internet connectivity"

    if check_connectivity 3 8.8.8.8; then
        log_subsection "Downloading latest pacman.conf from GitHub"
        if execute_or_dryrun "Download pacman.conf from GitHub" sudo wget "${github_url}" -O /etc/pacman.conf; then
            log_success "pacman.conf downloaded successfully"
            return 0
        else
            log_warn "Failed to download pacman.conf from GitHub"
            exit 1
        fi
    else
        log_error "No internet connectivity — cannot proceed: no local file and no internet"
        exit 1
    fi
}

main "$@"
