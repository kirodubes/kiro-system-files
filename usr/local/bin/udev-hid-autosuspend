#!/bin/bash
set -euo pipefail
# Udev helper: disable autosuspend on the USB parent of an HID interface.
# Invoked by udev RUN+ with %p (devpath) as $1.
[[ $# -eq 1 ]] || exit 1
PARENT="/sys$(dirname "$1")"
[[ -d "$PARENT" ]] || exit 0
echo -1 > "${PARENT}/power/autosuspend_delay_ms" 2>/dev/null || true
echo on  > "${PARENT}/power/control"              2>/dev/null || true
