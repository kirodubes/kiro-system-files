#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false

main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Install a curated set of development and desktop tools" \
                    "[--help] [--version] [--dry-run]" \
                    ""
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            *)
                log_error "Unknown option: $arg"
                exit 1
                ;;
        esac
    done

    execute_or_dryrun "Refresh databases" sudo pacman -Syy
    execute_or_dryrun "Install sublime-text-4" sudo pacman -S sublime-text-4 --noconfirm --needed
    execute_or_dryrun "Install ripgrep" sudo pacman -S ripgrep --noconfirm --needed
    execute_or_dryrun "Install meld" sudo pacman -S meld --noconfirm --needed
    execute_or_dryrun "Install thunar" sudo pacman -S thunar --noconfirm --needed
    execute_or_dryrun "Install thunar-archive-plugin" sudo pacman -S thunar-archive-plugin --noconfirm --needed
    execute_or_dryrun "Install thunar-volman" sudo pacman -S thunar-volman --noconfirm --needed
    log_success "$(basename "$0") done"
}

main "$@"
